{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "ZeroApi",
  "version": "1.1.3",
  "identifier": "com.zeroapi.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ZeroApi · 零登录 零云端 零 CORS",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' ipc: http://ipc.localhost https:; worker-src 'self' blob:;",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "零登录 零云端 零 CORS 的 API 调试工具",
    "longDescription": "ZeroApi 是一款基于 Tauri + Rust 构建的轻量级 API 调试工具,完全本地化运行,无需登录、无需云端、无 CORS 限制。支持 HTTP 七种方法、cURL 导入、环境变量、收藏与历史记录,以及应用内自动更新。",
    "publisher": "ZeroApi",
    "copyright": "Copyright © 2026 ZeroApi",
    "homepage": "https://github.com/jshmztl/zeroApi",
    "windows": {
      "wix": {
        "language": ["zh-CN", "en-US"]
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "languages": ["SimpChinese", "English"]
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": ["https://github.com/jshmztl/zeroApi/releases/latest/download/latest.json"],
      "pubkey": "",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
