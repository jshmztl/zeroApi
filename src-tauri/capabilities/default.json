{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "ZeroApi 默认权限",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:app:default",
    "core:event:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "core:path:default",
    "core:image:default",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "shell:default",
    "os:default"
  ]
}
